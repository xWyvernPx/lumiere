# pnpm config. Tolerate one known, intentional unmet peer rather than failing
# the install: i18next lists an optional typescript@"^5 || ^6" peer while this
# project is on TS 7. (pnpm's default is already lenient; this is explicit so a
# stricter global config can't break installs here.)
strict-peer-dependencies=false

# @le-cogito scope → Azure Artifacts feed (mirrors the server). Holds the pinned
# @le-cogito/lumiere-activity-schemas contract package. Auth is injected at
# runtime by the CI pipeline; locally, configure a feed credential in your
# user-level ~/.npmrc before `pnpm install`.
@le-cogito:registry=https://pkgs.dev.azure.com/le-cogito/_packaging/le-cogito/npm/registry/
